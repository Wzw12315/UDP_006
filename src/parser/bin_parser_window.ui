<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>BinParserWindow</class>
 <widget class="QWidget" name="BinParserWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1000</width>
    <height>850</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Bin文件解析与数据验证工具</string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <layout class="QHBoxLayout" name="fileLayout">
     <item>
      <widget class="QLineEdit" name="filePathLineEdit"/>
     </item>
     <item>
      <widget class="QPushButton" name="selectFileButton">
       <property name="text">
        <string>选择文件</string>
       </property>
      </widget>
     </item>
    </layout>
   </item>
   <item>
    <layout class="QHBoxLayout" name="fileLayout2">
     <item>
      <widget class="QLineEdit" name="filePathLineEdit2"/>
     </item>
     <item>
      <widget class="QPushButton" name="selectFile2Button">
       <property name="text">
        <string>选择第二个文件</string>
       </property>
      </widget>
     </item>
    </layout>
   </item>
   <item>
    <layout class="QHBoxLayout" name="buttonLayout">
     <item>
      <widget class="QPushButton" name="parseButton">
       <property name="text">
        <string>解析文件</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="cancelParseButton">
       <property name="enabled">
        <bool>false</bool>
       </property>
       <property name="text">
        <string>取消解析</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="verifyButton">
       <property name="text">
        <string>验证CRC</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="compareButton">
       <property name="text">
        <string>对比文件</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="convertToCsvButton">
       <property name="text">
        <string>导出CSV</string>
       </property>
       <property name="flat">
        <bool>false</bool>
       </property>
      </widget>
     </item>
    </layout>
   </item>
   <item>
    <widget class="QTableWidget" name="dataTableWidget">
     <property name="minimumSize">
      <size>
       <width>0</width>
       <height>300</height>
      </size>
     </property>
     <property name="horizontalHeaderLabels" stdset="0">
      <stringlist>
       <string>序号</string>
       <string>接收CRC</string>
       <string>计算CRC</string>
       <string>CRC匹配</string>
       <string>数据预览</string>
      </stringlist>
     </property>
    </widget>
   </item>
   <item>
    <layout class="QHBoxLayout" name="paginationLayout">
     <item>
      <widget class="QPushButton" name="prevPageButton">
       <property name="text">
        <string>上一页</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QLabel" name="pageInfoLabel">
       <property name="text">
        <string>第 0/0 页</string>
       </property>
       <property name="alignment">
        <set>Qt::AlignCenter</set>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QPushButton" name="nextPageButton">
       <property name="text">
        <string>下一页</string>
       </property>
      </widget>
     </item>
    </layout>
   </item>
   <item>
    <widget class="QTableWidget" name="compareTableWidget">
     <property name="minimumSize">
      <size>
       <width>0</width>
       <height>300</height>
      </size>
     </property>
     <property name="horizontalHeaderLabels" stdset="0">
      <stringlist>
       <string>序号</string>
       <string>文件1数据</string>
       <string>文件2数据</string>
       <string>对比结果</string>
      </stringlist>
     </property>
    </widget>
   </item>
   <item>
    <widget class="QTextEdit" name="logTextEdit"/>
   </item>
   <item>
    <widget class="QLabel" name="statusLabel">
     <property name="text">
      <string>请选择bin文件并解析</string>
     </property>
    </widget>
   </item>
  </layout>
 </widget>
 <resources/>
